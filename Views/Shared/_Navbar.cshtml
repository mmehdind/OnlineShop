@using OnlineShop.Common


<nav class="navbar navbar-expand-lg navbar-dark navbar-custom shadow-sm">

    <div class="container">

        <a class="navbar-brand fw-bold"
           asp-controller="Home"
           asp-action="Index">

            OnlineShop

        </a>

        <button class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarContent">

            <span class="navbar-toggler-icon"></span>

        </button>

        <div class="collapse navbar-collapse"
             id="navbarContent">

            <ul class="navbar-nav">

                <li class="nav-item">

                    <a class="nav-link"
                       asp-controller="Product"
                       asp-action="Index">

                        @SiteTexts.Navigation.Products

                    </a>

                </li>

            </ul>

            <ul class="navbar-nav align-items-center">

                <li class="nav-item">

                    <a class="nav-link cart-link"
                       asp-controller="Cart"
                       asp-action="Index">

                        🛒

                    </a>

                </li>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item dropdown">

                        <a class="nav-link dropdown-toggle"
                           href="#"
                           role="button"
                           data-bs-toggle="dropdown">

                            @User.Identity.Name

                        </a>

                        <ul class="dropdown-menu dropdown-menu-end">

                            <li>

                                <form asp-controller="Auth"
                                      asp-action="Logout"
                                      method="post">

                                    <button class="dropdown-item"
                                            type="submit">

                                        @SiteTexts.Navigation.Logout

                                    </button>

                                </form>

                            </li>

                        </ul>

                    </li>
                }
                else
                {
                    <li class="nav-item">

                        <a class="nav-link"
                           asp-controller="Auth"
                           asp-action="Login">

                            @SiteTexts.Navigation.Login

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link"
                           asp-controller="Auth"
                           asp-action="Register">

                            @SiteTexts.Navigation.Register

                        </a>

                    </li>
                }

            </ul>

        </div>

    </div>

</nav>