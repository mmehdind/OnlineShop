@using OnlineShop.Common

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>

    <title>@ViewData["Title"] - پنل مدیریت</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.rtl.min.css"
          rel="stylesheet">

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/admin-layout.css"/>

    @await RenderSectionAsync("Styles", false)
</head>
<body>

<div class="admin-wrapper">

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">

        <div class="sidebar-header">
            <h4>پنل مدیریت</h4>
        </div>

        <ul class="sidebar-menu">

            <li>
                <a asp-area="Admin"
                   asp-controller="Dashboard"
                   asp-action="Index">
                    <i class="bi bi-speedometer2"></i>
                    داشبورد
                </a>
            </li>

            <li>
                <button class="submenu-btn">
                    <span>
                        <i class="bi bi-box"></i>
                        محصولات
                    </span>

                    <i class="bi bi-chevron-down"></i>
                </button>

                <ul class="submenu">
                    <li>
                        <a asp-area="Admin"
                           asp-controller="Product"
                           asp-action="Index">
                            لیست محصولات
                        </a>
                    </li>

                    <li>
                        <a asp-area="Admin"
                           asp-controller="Product"
                           asp-action="Create">
                            افزودن محصول
                        </a>
                    </li>
                </ul>
            </li>

            <li>
                <a asp-area="Admin"
                   asp-controller="Category"
                   asp-action="Index">
                    <i class="bi bi-grid"></i>
                    دسته‌بندی‌ها
                </a>
            </li>

            <li>
                <a asp-area="Admin"
                   asp-controller="Order"
                   asp-action="Index">
                    <i class="bi bi-cart3"></i>
                    سفارشات
                </a>
            </li>

            <li>
                <a asp-area="Admin"
                   asp-controller="User"
                   asp-action="Index">
                    <i class="bi bi-people"></i>
                    کاربران
                </a>
            </li>

            <li>
                <a asp-area="Admin"
                   asp-controller="Report"
                   asp-action="Index">
                    <i class="bi bi-bar-chart"></i>
                    گزارشات
                </a>
            </li>

            <li>
                <a asp-area="Admin"
                   asp-controller="Discount"
                   asp-action="Index">
                    <i class="bi bi-ticket-perforated"></i>
                    تخفیف‌ها
                </a>
            </li>

            <li>
                <a asp-area="Admin"
                   asp-controller="Setting"
                   asp-action="Index">
                    <i class="bi bi-gear"></i>
                    تنظیمات
                </a>
            </li>

            <li>
                <a asp-area="Admin"
                   asp-controller="Account"
                   asp-action="Logout">
                    <i class="bi bi-box-arrow-right"></i>
                    خروج
                </a>
            </li>

        </ul>

    </aside>


    <main class="main-content">

        <header class="topbar">

            <button class="menu-btn" id="menuBtn">
                <i class="bi bi-list"></i>
            </button>

            <div class="topbar-left">

                <button class="notification-btn">
                    <i class="bi bi-bell"></i>
                </button>

                <div class="admin-name">
                    سلام، ادمین
                </div>

            </div>

        </header>


        <div class="content-container">
            @RenderBody()
        </div>

    </main>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

<script src="~/js/admin-layout.js"></script>

@await RenderSectionAsync("Scripts", false)

</body>
</html>