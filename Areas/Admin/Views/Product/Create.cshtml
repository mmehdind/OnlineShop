@model OnlineShop.Admin.ViewModels.Product.ProductCreateVm

@{
    ViewData["Title"] = "افزودن محصول";
}

@section Styles {
    <link rel="stylesheet" href="~/css/product.css" />
}

<form asp-action="Create" method="post" enctype="multipart/form-data">

    <partial name="_ProductForm" model="Model" />

    <div class="mt-4">
        <button type="submit" class="btn btn-primary">
             ذخیره
            </button>

        <a  asp-area="Admin"
            asp-action="Index" class="btn btn-outline-secondary">
                 بازگشت
        </a>
    </div>

</form>