@model OnlineShop.Admin.ViewModels.Product.ProductAdminVm

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h3 class="mb-4">Product Details</h3>

<div class="row">

    <!-- Images -->
    <div class="col-md-6">

        <div class="card p-3 shadow-sm border-0">

            <img id="mainImage"
                 src="@Model.Images.FirstOrDefault(x => x.IsMain)?.ImageUrl"
                 class="img-fluid rounded mb-3" />

            <div class="d-flex gap-2 flex-wrap">

                @foreach (var img in Model.Images)
                {
                    <img src="@img.ImageUrl"
                         class="img-thumbnail"
                         style="width:80px;height:80px;object-fit:cover;cursor:pointer"
                         onclick="changeImage(this)" />
                }

            </div>

        </div>

    </div>

    <!-- Info -->
    <div class="col-md-6">

        <div class="card p-4 shadow-sm border-0">

            <h4>@Model.Name</h4>

            <hr />

            <p><b>Price:</b> @Model.Price.ToString("N0")</p>
            <p><b>Stock:</b> @Model.Stock</p>
            <p><b>Category:</b> @Model.CategoryName</p>

            <hr />

            <p>@Model.Description</p>

        </div>

    </div>

</div>

<script>
    function changeImage(img) {
        document.getElementById("mainImage").src = img.src;
    }
</script>